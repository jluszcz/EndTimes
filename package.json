{
  "name": "endtimes",
  "version": "1.0.0",
  "description": "A web application that calculates movie end times including trailer/preview duration",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "keywords": [
    "movies",
    "tmdb",
    "cloudflare-workers"
  ],
  "author": "Jacob Luszcz",
  "license": "MIT",
  "overrides": {
    "undici": "^7.28.0",
    "picomatch": "^4.0.4"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.16.19",
    "@cloudflare/workers-types": "^4.20260317.1",
    "@eslint/js": "^10.0.1",
    "eslint": "^10.6.0",
    "globals": "^17.7.0",
    "prettier": "^3.9.4",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9",
    "wrangler": "^4.75.0"
  }
}
